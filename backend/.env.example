# Copy this file to ".env" and fill in real values.
# Never commit the real .env file or share these values publicly.

# From Supabase: Settings > API > Project URL
SUPABASE_URL=

# From Supabase: Settings > API > anon public key
SUPABASE_ANON_KEY=

# From Supabase: Settings > API > service_role key (secret! server-side only)
SUPABASE_SERVICE_ROLE_KEY=

# From console.anthropic.com > API Keys
ANTHROPIC_API_KEY=

# Port the server runs on locally
PORT=3000
